root = true

[*]
end_of_line = lf
insert_final_newline = true

[*.sh]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[Procfile]
insert_final_newline = false
trim_trailing_whitespace = true

[*.{clj,cljs,cljc,edn}]
indent_style = space
trim_trailing_whitespace = true

[*.{js,jsx}]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.sql]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{yaml,yml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
